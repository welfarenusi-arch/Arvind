rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }
    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerUid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             (!('email' in data) || data.email == null || data.email is string) &&
             (!('phone' in data) || data.phone == null || data.phone is string) &&
             (!('city' in data) || data.city == null || data.city is string) &&
             (!('priority' in data) || data.priority == null || data.priority in ['High', 'Medium', 'Low']) &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.status in ['New', 'Contacted', 'Qualified', 'Converted', 'Lost'] &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /leads/{leadId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isNewDocOwner() && isValidLead(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isNewDocOwner() && isValidLead(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /followups/{followupId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUid == request.auth.uid && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    // Connection test path
    match /test/connection {
      allow read: if true;
    }
  }
}
